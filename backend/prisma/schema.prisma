generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  role      String   @default("viewer") // admin | editor | viewer
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events             Event[]              @relation("EventOwner")
  notes              Note[]               @relation("NoteOwner")
  marketPurchases    MarketPurchase[]     @relation("MarketPurchaseOwner")
  providers          Provider[]           @relation("ProviderOwner")
  catalogItems       CatalogItem[]        @relation("CatalogItemOwner")
  fixedCosts         FixedCost[]          @relation("FixedCostOwner")
  recipes            RecipeCombo[]        @relation("RecipeComboOwner")
  quoteTemplates     QuoteTemplate[]      @relation("QuoteTemplateOwner")
  purchaseItems      MarketPurchaseItem[] @relation("MarketPurchaseItemOwner")
  eventTasks         EventTask[]          @relation("EventTaskOwner")
  eventPayments      EventPayment[]       @relation("EventPaymentOwner")
  stockMovements     StockMovement[]      @relation("StockMovementOwner")
  noteChangeLogs     NoteChangeLog[]      @relation("NoteChangeLogOwner")
  eventChangeLogs    EventChangeLog[]     @relation("EventChangeLogOwner")
  eventPhotos        EventPhoto[]         @relation("EventPhotoOwner")
  insumos            Insumo[]             @relation("InsumoOwner")
  clients            Client[]             @relation("ClientOwner")
  employees          Employee[]           @relation("EmployeeOwner")
  employeeActivities EmployeeActivity[]   @relation("EmployeeActivityOwner")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("ClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  events    Event[]
}

model Employee {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  email       String?
  role        String   @default("Cocinero")
  hourlyRate  Float    @default(0)
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("EmployeeOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  activities  EmployeeActivity[]
}

model EmployeeActivity {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  hours       Float
  description String?
  paymentType String   @default("Por hora")
  payment     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId      String?
  owner        User?    @relation("EmployeeActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  eventId      String?
  event        Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Event {
  id           String   @id @default(uuid())
  title        String
  client       String?
  date         String?
  time         String?
  location     String?
  guests       Int      @default(0)
  status       String   @default("Pendiente")
  menuNotes    String?
  recipeName   String?
  extraCosts   Float    @default(0)
  profitMargin Float    @default(0)
  totalPrice   Float    @default(0)
  amountPaid   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId      String?
  owner        User?    @relation("EventOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  clientId     String?
  clientRef    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  insumos      Insumo[]
  tasks        EventTask[]
  payments     EventPayment[]
  purchases    MarketPurchase[]
  changelog    EventChangeLog[]
  photos       EventPhoto[]
  employeeActivities EmployeeActivity[]
}

model CatalogItem {
  id        String   @id @default(uuid())
  name      String
  unit      String
  price     Float
  stock     Float    @default(0)
  minStock  Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("CatalogItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  movements StockMovement[]
}

model MarketPurchase {
  id            String   @id @default(uuid())
  purchasedAt   DateTime @default(now())
  store         String
  vendorName    String?
  vendorPhone   String?
  paymentMethod String
  totalAmount   Float    @default(0)
  notes         String?
  receiptPhotos String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("MarketPurchaseOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId       String?
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  providerId    String?
  provider      Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items         MarketPurchaseItem[]
}

model MarketPurchaseItem {
  id             String @id @default(uuid())
  name           String
  quantity       Float
  unit           String
  unitPrice      Float
  subtotal       Float

  ownerId        String?
  owner          User?    @relation("MarketPurchaseItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  purchaseId     String
  purchase       MarketPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
}

model Provider {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  category  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("ProviderOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  purchases MarketPurchase[]
}

model RecipeCombo {
  id          String   @id @default(uuid())
  name        String
  category    String?
  description String?
  servings    Int      @default(0)
  basePrice   Float    @default(0)
  itemsJson   String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("RecipeComboOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model EventTask {
  id        String   @id @default(uuid())
  title     String
  dueDate   String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId   String?
  owner     User?    @relation("EventTaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventPayment {
  id            String   @id @default(uuid())
  paidAt        DateTime @default(now())
  amount        Float
  paymentMethod String
  notes         String?
  createdAt     DateTime @default(now())

  ownerId   String?
  owner     User?    @relation("EventPaymentOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id            String   @id @default(uuid())
  type          String
  quantity      Float
  notes         String?
  createdAt     DateTime @default(now())

  ownerId   String?
  owner     User?    @relation("StockMovementOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  catalogItemId String
  catalogItem   CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
}

model Note {
  id                 String   @id @default(uuid())
  title              String
  content            String?
  status             String   @default("Pendiente")
  priority           String   @default("Media")
  type               String   @default("Recordatorio")
  dueDate            String?
  pinned             Boolean  @default(false)
  linkedType         String   @default("general")
  linkedId           String?
  tags               String   @default("[]")
  done               Boolean  @default(false)
  archived           Boolean  @default(false)
  recurrence         String   @default("none")
  recurrenceParentId String?

  ownerId            String?
  owner              User?    @relation("NoteOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  changelog          NoteChangeLog[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model NoteChangeLog {
  id        String   @id @default(uuid())
  field     String
  oldValue  String?
  newValue  String?
  ownerId   String?
  owner     User?    @relation("NoteChangeLogOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model QuoteTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  guests       Int      @default(0)
  extraCosts   Float    @default(0)
  profitMargin Float    @default(0)
  menuNotes    String?
  recipeName   String?
  itemsJson    String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId      String?
  owner        User?    @relation("QuoteTemplateOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}


model EventChangeLog {
  id         String   @id @default(uuid())
  field      String   // "status" | "totalPrice"
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  ownerId    String?
  owner      User?    @relation("EventChangeLogOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FixedCost {
  id          String   @id @default(uuid())
  name        String
  amount      Float
  frequency   String   @default("Mensual") // Mensual | Anual | Por evento
  category    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?
  owner       User?    @relation("FixedCostOwner", fields: [ownerId], references: [id], onDelete: SetNull)
}

model EventPhoto {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  data      String   // base64
  size      Int
  caption   String?
  createdAt DateTime @default(now())

  ownerId   String?
  owner     User?    @relation("EventPhotoOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Insumo {
  id          String @id @default(uuid())
  name        String
  quantity    Float
  unit        String
  costPerUnit Float
  totalCost   Float

  ownerId     String?
  owner       User?  @relation("InsumoOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  eventId     String
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
